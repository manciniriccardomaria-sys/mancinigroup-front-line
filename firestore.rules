rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isApprovedAdminEmail() {
      return isAuthenticated() &&
        request.auth.token.email in [
          "manciniriccardomaria@gmail.com",
          "pasqualemancini62@gmail.com",
          "davidedalianipoli@gmail.com"
        ];
    }

    function isApprovedEmployeeEmail() {
      return isAuthenticated() &&
        request.auth.token.email in [
          "b.marinamancinigroup@gmail.com",
          "isabella.cappelluti@gmail.com",
          "nicolemancinigroup@gmail.com",
          "rossellamancinigroup@gmail.com",
          "s.angelamancinigroup@gmail.com",
          "valeriamancinigroup@gmail.com",
          "gaetanocalo73@gmail.com"
        ];
    }

    function isApprovedUserEmail() {
      return isApprovedAdminEmail() || isApprovedEmployeeEmail();
    }

    function isAdmin() {
      return isApprovedAdminEmail();
    }

    function ownsReportId(reportId) {
      return isApprovedEmployeeEmail() &&
        reportId.matches(request.auth.uid + '_.*');
    }

    function roleMatchesApprovedEmail(data) {
      return (isApprovedAdminEmail() && data.role == 'admin') ||
        (isApprovedEmployeeEmail() && data.role == 'employee');
    }

    // ===============================================================
    // Data Validation
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 150 &&
             data.role in ['employee', 'admin'];
    }

    function isValidDailyReport(data) {
      return data.keys().hasAll(['userId', 'userName', 'date']) &&
             data.userId is string && data.userId.size() < 128 &&
             data.userName is string && data.userName.size() < 100 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (!('values' in data) ||
               data.values is map && data.values.size() <= 100) &&
             // Validate all counters are integers >= 0
             (!('incassi' in data) || data.incassi is int && data.incassi >= 0) &&
             (!('recensioni' in data) || data.recensioni is int && data.recensioni >= 0) &&
             (!('prevMotorSe' in data) || data.prevMotorSe is int && data.prevMotorSe >= 0) &&
             (!('prevMotorTerzi' in data) || data.prevMotorTerzi is int && data.prevMotorTerzi >= 0) &&
             (!('prevRetailSe' in data) || data.prevRetailSe is int && data.prevRetailSe >= 0) &&
             (!('prevRetailTerzi' in data) || data.prevRetailTerzi is int && data.prevRetailTerzi >= 0) &&
             (!('emissMotorSe' in data) || data.emissMotorSe is int && data.emissMotorSe >= 0) &&
             (!('emissRetailSe' in data) || data.emissRetailSe is int && data.emissRetailSe >= 0) &&
             (!('infoVarie' in data) || data.infoVarie is int && data.infoVarie >= 0) &&
             (!('smeg' in data) || data.smeg is int && data.smeg >= 0) &&
             (!('vitarivConsegna' in data) || data.vitarivConsegna is int && data.vitarivConsegna >= 0) &&
             (!('longevityCare' in data) || data.longevityCare is int && data.longevityCare >= 0) &&
             (!('winbackMag25' in data) || data.winbackMag25 is int && data.winbackMag25 >= 0) &&
             (!('scegliAllianzGen26' in data) || data.scegliAllianzGen26 is int && data.scegliAllianzGen26 >= 0) &&
             (!('scegliAllianzConsegna' in data) || data.scegliAllianzConsegna is int && data.scegliAllianzConsegna >= 0) &&
             (!('sinistriRetail' in data) || data.sinistriRetail is int && data.sinistriRetail >= 0) &&
             (!('contattiProtection' in data) || data.contattiProtection is int && data.contattiProtection >= 0) &&
             (!('contattiNoleggio' in data) || data.contattiNoleggio is int && data.contattiNoleggio >= 0) &&
             // Legacy fields are still accepted for existing historical reports.
             (!('emissSe' in data) || data.emissSe is int && data.emissSe >= 0) &&
             (!('emissTerzi' in data) || data.emissTerzi is int && data.emissTerzi >= 0) &&
             (!('sinistriMotor' in data) || data.sinistriMotor is int && data.sinistriMotor >= 0) &&
             (!('sinistriRamiVari' in data) || data.sinistriRamiVari is int && data.sinistriRamiVari >= 0) &&
             (!('midCorporate' in data) || data.midCorporate is int && data.midCorporate >= 0) &&
             (!('contattiVita' in data) || data.contattiVita is int && data.contattiVita >= 0) &&
             (!('contattiFondoPensione' in data) || data.contattiFondoPensione is int && data.contattiFondoPensione >= 0) &&
             (!('contattiEnergia' in data) || data.contattiEnergia is int && data.contattiEnergia >= 0);
    }

    function isValidCampaign(data) {
      return data.keys().hasAll([
        'name',
        'description',
        'monthsAfterStart',
        'active'
      ]) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.description is string && data.description.size() < 500 &&
        data.monthsAfterStart is int &&
        data.monthsAfterStart > 0 && data.monthsAfterStart <= 120 &&
        data.active is bool;
    }

    function isValidNotice(data) {
      return data.keys().hasAll([
        'title',
        'body',
        'active',
        'createdBy'
      ]) &&
        data.title is string &&
        data.title.size() > 0 && data.title.size() <= 120 &&
        data.body is string &&
        data.body.size() > 0 && data.body.size() <= 3000 &&
        data.active is bool &&
        data.createdBy is string &&
        data.createdBy.size() > 0 && data.createdBy.size() < 150;
    }

    function isValidDailyObjectives(data) {
      return data.keys().hasAll(['enabled', 'values']) &&
        data.enabled is bool &&
        data.values is map && data.values.size() <= 100 &&
        (!('byUser' in data) ||
          data.byUser is map && data.byUser.size() <= 100) &&
        (!('updatedBy' in data) ||
          data.updatedBy is string && data.updatedBy.size() < 150) &&
        (!('incassi' in data) || data.incassi is int && data.incassi >= 0) &&
        (!('recensioni' in data) || data.recensioni is int && data.recensioni >= 0) &&
        (!('prevMotorSe' in data) || data.prevMotorSe is int && data.prevMotorSe >= 0) &&
        (!('prevMotorTerzi' in data) || data.prevMotorTerzi is int && data.prevMotorTerzi >= 0) &&
        (!('prevRetailSe' in data) || data.prevRetailSe is int && data.prevRetailSe >= 0) &&
        (!('prevRetailTerzi' in data) || data.prevRetailTerzi is int && data.prevRetailTerzi >= 0) &&
        (!('emissMotorSe' in data) || data.emissMotorSe is int && data.emissMotorSe >= 0) &&
        (!('emissRetailSe' in data) || data.emissRetailSe is int && data.emissRetailSe >= 0) &&
        (!('infoVarie' in data) || data.infoVarie is int && data.infoVarie >= 0) &&
        (!('smeg' in data) || data.smeg is int && data.smeg >= 0) &&
        (!('vitarivConsegna' in data) || data.vitarivConsegna is int && data.vitarivConsegna >= 0) &&
        (!('longevityCare' in data) || data.longevityCare is int && data.longevityCare >= 0) &&
        (!('winbackMag25' in data) || data.winbackMag25 is int && data.winbackMag25 >= 0) &&
        (!('scegliAllianzGen26' in data) || data.scegliAllianzGen26 is int && data.scegliAllianzGen26 >= 0) &&
        (!('scegliAllianzConsegna' in data) || data.scegliAllianzConsegna is int && data.scegliAllianzConsegna >= 0) &&
        (!('sinistriMotor' in data) || data.sinistriMotor is int && data.sinistriMotor >= 0) &&
        (!('sinistriRetail' in data) || data.sinistriRetail is int && data.sinistriRetail >= 0) &&
        (!('midCorporate' in data) || data.midCorporate is int && data.midCorporate >= 0) &&
        (!('contattiFondoPensione' in data) || data.contattiFondoPensione is int && data.contattiFondoPensione >= 0) &&
        (!('contattiProtection' in data) || data.contattiProtection is int && data.contattiProtection >= 0) &&
        (!('contattiEnergia' in data) || data.contattiEnergia is int && data.contattiEnergia >= 0) &&
        (!('contattiNoleggio' in data) || data.contattiNoleggio is int && data.contattiNoleggio >= 0);
    }

    function isValidReportCategory(data) {
      return data.keys().hasAll([
        'label',
        'sectionId',
        'iconKey',
        'color',
        'order'
      ]) &&
        data.label is string &&
        data.label.size() > 0 && data.label.size() <= 100 &&
        data.sectionId in ['reception', 'priority', 'other'] &&
        data.iconKey in [
          'banknote',
          'car',
          'car-front',
          'file-check',
          'home',
          'house-plus',
          'info',
          'store',
          'chart',
          'heart',
          'phone',
          'book-check',
          'shopping-bag',
          'shield-alert',
          'shield-check',
          'briefcase',
          'piggy-bank',
          'zap',
          'star',
          'key',
          'target',
          'users',
          'message',
          'mail',
          'calendar-check',
          'clipboard-check',
          'dollar'
        ] &&
        data.color in [
          'text-blue-600',
          'text-indigo-600',
          'text-violet-600',
          'text-fuchsia-600',
          'text-pink-600',
          'text-rose-600',
          'text-cyan-600',
          'text-green-600',
          'text-emerald-600',
          'text-amber-600',
          'text-orange-600',
          'text-yellow-600'
        ] &&
        data.order is int && data.order >= 0 && data.order <= 100000;
    }

    function isValidCallTask(data) {
      return data.keys().hasAll([
        'importType',
        'category',
        'categoryLabel',
        'clientName',
        'sourceCode',
        'sourceName',
        'eventDate',
        'dueDate',
        'status',
        'sourceFingerprint'
      ]) &&
        data.importType in ['newClients', 'expirations', 'winback'] &&
        data.category in [
          'campagna',
          'scadenza_rata',
          'scadenza_annuale',
          'winback'
        ] &&
        data.categoryLabel is string && data.categoryLabel.size() < 150 &&
        data.clientName is string &&
        data.clientName.size() > 0 && data.clientName.size() < 200 &&
        data.sourceCode is string && data.sourceCode.size() < 20 &&
        data.sourceName is string && data.sourceName.size() < 200 &&
        data.eventDate is string &&
        data.eventDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.dueDate is string &&
        data.dueDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.status in [
          'da_chiamare',
          'chiamato',
          'da_richiamare',
          'non_raggiungibile',
          'cambio_rottamazione_macchina',
          'non_gradito',
          'ripreso',
          'cliente_perso'
        ] &&
        data.sourceFingerprint is string &&
        data.sourceFingerprint.size() > 0 && data.sourceFingerprint.size() < 100 &&
        (!('callbackDate' in data) ||
          data.callbackDate is string &&
          data.callbackDate.matches('^\\d{4}-\\d{2}-\\d{2}$')) &&
        (!('calledDate' in data) ||
          data.calledDate is string &&
          data.calledDate.matches('^\\d{4}-\\d{2}-\\d{2}$')) &&
        (data.status != 'da_richiamare' || 'callbackDate' in data);
    }

    function isValidNewClient(data) {
      return data.keys().hasAll([
        'id',
        'clientName',
        'phone',
        'sourceCode',
        'sourceName',
        'sourceOwnerEmail',
        'sourceOwnerName',
        'coverages',
        'birthDate',
        'relationshipStartDate',
        'sourceFingerprint'
      ]) &&
        data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
        data.clientName is string &&
        data.clientName.size() > 0 && data.clientName.size() < 200 &&
        data.phone is string && data.phone.size() < 100 &&
        data.sourceCode is string && data.sourceCode.size() < 20 &&
        data.sourceName is string && data.sourceName.size() < 200 &&
        data.sourceOwnerEmail is string && data.sourceOwnerEmail.size() < 150 &&
        data.sourceOwnerName is string && data.sourceOwnerName.size() < 100 &&
        data.coverages is string && data.coverages.size() < 1000 &&
        data.birthDate is string &&
        (data.birthDate == '' ||
          data.birthDate.matches('^\\d{4}-\\d{2}-\\d{2}$')) &&
        data.relationshipStartDate is string &&
        data.relationshipStartDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.sourceFingerprint is string &&
        data.sourceFingerprint.size() > 0 && data.sourceFingerprint.size() < 100;
    }

    function employeeCanUpdateCallTask() {
      return isApprovedEmployeeEmail() &&
        (!('assignedToUid' in resource.data) ||
          resource.data.assignedToUid == '' ||
          resource.data.assignedToUid == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'callbackDate',
          'calledDate',
          'assignedToUid',
          'assignedToEmail',
          'assignedToName',
          'updatedByUid',
          'updatedByName',
          'updatedAt'
        ]) &&
        request.resource.data.assignedToUid == request.auth.uid &&
        request.resource.data.assignedToEmail == request.auth.token.email &&
        request.resource.data.updatedByUid == request.auth.uid;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if (isOwner(userId) && isApprovedUserEmail()) || isAdmin();
      allow create: if isValidUser(request.resource.data) &&
        (((isOwner(userId) && isApprovedUserEmail()) &&
          request.resource.data.email == request.auth.token.email &&
          roleMatchesApprovedEmail(request.resource.data)) ||
         isAdmin());
      allow update: if isValidUser(request.resource.data) &&
        (((isOwner(userId) && isApprovedUserEmail()) &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == request.auth.token.email &&
          roleMatchesApprovedEmail(request.resource.data)) ||
         isAdmin());
    }

    match /daily_reports/{reportId} {
      allow get: if ownsReportId(reportId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isValidDailyReport(request.resource.data) &&
        ((ownsReportId(reportId) && request.resource.data.userId == request.auth.uid) || isAdmin());
    }

    match /campaigns/{campaignId} {
      allow read: if isApprovedUserEmail();
      allow create, update: if isAdmin() && isValidCampaign(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if isApprovedUserEmail();
      allow create, update: if isAdmin() &&
        isValidNotice(request.resource.data);
      allow delete: if isAdmin();
    }

    match /daily_objectives/{objectiveId} {
      allow read: if isApprovedUserEmail();
      allow create, update: if isAdmin() &&
        objectiveId == 'current' &&
        isValidDailyObjectives(request.resource.data);
      allow delete: if isAdmin();
    }

    match /report_categories/{categoryId} {
      allow read: if isApprovedUserEmail();
      allow create, update: if isAdmin() &&
        isValidReportCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /call_tasks/{taskId} {
      allow read: if isApprovedUserEmail();
      allow create: if isAdmin() && isValidCallTask(request.resource.data);
      allow update: if isValidCallTask(request.resource.data) &&
        (isAdmin() || employeeCanUpdateCallTask());
      allow delete: if isAdmin();
    }

    match /new_clients/{clientId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() &&
        isValidNewClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /import_runs/{runId} {
      allow read, create: if isAdmin();
    }
  }
}

{
  "entities": {
    "User": {
      "title": "User",
      "description": "Dipendente o Agente dell'agenzia ManciniGroup.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin"] }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "DailyReport": {
      "title": "Daily Report",
      "description": "Rendicontazione giornaliera per dipendente.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "incassi": { "type": "integer" },
        "prevMotorSe": { "type": "integer" },
        "emissMotorSe": { "type": "integer" },
        "prevRetailSe": { "type": "integer" },
        "emissRetailSe": { "type": "integer" },
        "infoVarie": { "type": "integer" },
        "smeg": { "type": "integer" },
        "vitarivConsegna": { "type": "integer" },
        "longevityCare": { "type": "integer" },
        "winbackMag25": { "type": "integer" },
        "scegliAllianzGen26": { "type": "integer" },
        "scegliAllianzConsegna": { "type": "integer" },
        "prevMotorTerzi": { "type": "integer" },
        "prevRetailTerzi": { "type": "integer" },
        "sinistriMotor": { "type": "integer" },
        "sinistriRetail": { "type": "integer" },
        "midCorporate": { "type": "integer" },
        "contattiFondoPensione": { "type": "integer" },
        "contattiProtection": { "type": "integer" },
        "contattiEnergia": { "type": "integer" },
        "recensioni": { "type": "integer" },
        "contattiNoleggio": { "type": "integer" }
      },
      "required": ["userId", "userName", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Informazioni sul profilo utente."
    },
    "/daily_reports/{reportId}": {
      "schema": "DailyReport",
      "description": "Dati di rendicontazione giornalieri."
    }
  }
}
